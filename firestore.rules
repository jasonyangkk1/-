rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidAnalysis(data) {
      // 放寬驗證以確保寫入成功，僅檢查最關鍵欄位是否存在
      let hasRequired = data.keys().hasAll(['stockId', 'rsi', 'judgment', 'createdAt']);
      return hasRequired;
    }

    // 針對 analyses_ 開頭的所有集合進行授權
    match /{collectionName}/{analysisId} {
      allow read, list, delete: if collectionName.startsWith('analyses');
      allow create: if collectionName.startsWith('analyses') && isValidAnalysis(request.resource.data);
      allow update: if false;
    }
  }
}
