rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidAnalysis(data) {
      // 核心必填欄位
      let coreFields = data.keys().hasAll(['stockId', 'rsi', 'judgment', 'createdAt']);
      
      return coreFields
        && data.stockId is string 
        && data.rsi is number
        && data.judgment in ['可以買進', '建議觀望']
        && data.createdAt is timestamp;
    }

    match /{collectionName}/{analysisId} {
      // 支援動態命名集合 (如 analyses_prod1, analyses_prod2) 以實現多環境隔離
      allow read, list: if collectionName.startsWith('analyses');
      allow create: if collectionName.startsWith('analyses') && isValidAnalysis(request.resource.data);
      allow delete: if collectionName.startsWith('analyses');
      allow update: if false; // Analysis records should be immutable
    }
  }
}
